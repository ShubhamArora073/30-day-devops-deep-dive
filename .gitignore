# ---------------------------------------------------------------------------
# Personal — local only, NEVER pushed.
# Narrative, coaching notes, LinkedIn drafts — all stay on disk only.
# ---------------------------------------------------------------------------
interview-introduction.md
interview-practice-plan.md
# All LinkedIn drafts stay local
linkedin-posts/
notes/
# Per-day personal coaching notes
notes.md
**/notes.md
# Production-grade eksctl variants are LOCAL ONLY.
# The repo ships dev/sandbox versions; you maintain prod versions on disk.
*.prod.yaml
scratch/
*.private.md

# ---------------------------------------------------------------------------
# Secrets & credentials — must never reach a public repo.
# ---------------------------------------------------------------------------
.env
.env.*
*.pem
*.key
*.crt
*.p12
*.pfx
credentials
.aws/
kubeconfig
kubeconfig.*
*.kubeconfig

# ---------------------------------------------------------------------------
# Terraform — state files contain secrets in plaintext (DB passwords, tokens).
# ---------------------------------------------------------------------------
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfvars
!example.tfvars
!*.example.tfvars
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc
tfplan
*.tfplan

# ---------------------------------------------------------------------------
# Kubernetes — generated/runtime artifacts.
# ---------------------------------------------------------------------------
*-kubeconfig
kube-config*
.kube/
.kubeconfig-*

# ---------------------------------------------------------------------------
# Per-lab run evidence — cluster-specific IDs, logs, timestamps. Not portable.
# Each lab's README explains how to regenerate evidence locally.
# ---------------------------------------------------------------------------
labs/*/evidence/*
!labs/*/evidence/.gitkeep

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
.pytest_cache/
.coverage
htmlcov/
*.egg-info/
dist/
build/

# ---------------------------------------------------------------------------
# Node / Helm
# ---------------------------------------------------------------------------
node_modules/
charts/*.tgz
*.lock

# ---------------------------------------------------------------------------
# IDE / OS
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Lab outputs / generated files
# ---------------------------------------------------------------------------
output.json
*.log
logs/
tmp/
.cache/
